# Garmin MCP Server Configuration
# Copy this file to .env and fill in your values

# Garmin Connect Credentials (Required)
GARMIN_EMAIL=your_email@example.com
GARMIN_PASSWORD=your_password

# MCP Server Configuration
MCP_TRANSPORT=stdio  # Options: stdio, http
MCP_HOST=localhost   # Only used for HTTP transport
MCP_PORT=8000       # Only used for HTTP transport

# Logging Configuration  
LOG_LEVEL=INFO      # Options: DEBUG, INFO, WARNING, ERROR
LOG_FORMAT=json     # Options: json, text

# Security Configuration (for HTTP transport)
OAUTH_CLIENT_ID=your_oauth_client_id
OAUTH_CLIENT_SECRET=your_oauth_client_secret
JWT_SECRET_KEY=your_jwt_secret_key_here_use_strong_random_string

# Cache Configuration
CACHE_TTL=300       # Cache TTL in seconds (5 minutes)
CACHE_TYPE=memory   # Options: memory, redis
REDIS_URL=redis://localhost:6379  # Only used if CACHE_TYPE=redis

# Rate Limiting
RATE_LIMIT_REQUESTS=60    # Requests per minute per client
RATE_LIMIT_WINDOW=60      # Window in seconds

# Performance Settings
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=30        # Request timeout in seconds
GARMIN_API_RATE_LIMIT=10  # Garmin API requests per minute

# Data Settings
DEFAULT_DATE_RANGE=7      # Default number of days for data queries
MAX_DATE_RANGE=90        # Maximum allowed date range

# Monitoring (Optional)
ENABLE_METRICS=false     # Enable Prometheus metrics
METRICS_PORT=9000       # Port for metrics endpoint

# Development Settings
DEVELOPMENT_MODE=false   # Enable development features
DEBUG_GARMIN_API=false  # Enable detailed Garmin API logging